# ==============================================================================
# BACKEND ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in real values.
#
# This project keeps LOCAL and PRODUCTION values in the same .env file —
# only one block should be uncommented (active) at a time.
# ==============================================================================

# ---------- LOCAL ----------
PORT=5000
MONGO_URI=mongodb://localhost:27017/emr_appointment
JWT_SECRET=emr_super_secret_jwt_key_123!
JWT_REFRESH_SECRET=emr_super_secret_jwt_refresh_key_456!
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# SMTP account used to send "Forgot Password" reset emails via nodemailer
# (see backend/services/email.service.js). For Gmail: EMAIL_HOST is always
# smtp.gmail.com, EMAIL_PORT is 587, and EMAIL_PASS must be a Gmail App
# Password (Google Account > Security > 2-Step Verification > App
# Passwords) — your regular Gmail login password will NOT work here.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# ---------- PRODUCTION (commented out — fill in real values before deploying) ----------
# PORT=5000
# MONGO_URI=<production MongoDB connection string>
# JWT_SECRET=<generate a new strong random secret — do not reuse the local one>
# JWT_REFRESH_SECRET=<generate a new strong random secret — do not reuse the local one>
# NODE_ENV=production
# FRONTEND_URL=<production frontend URL, e.g. https://app.yourdomain.com>
# EMAIL_HOST=<your SMTP provider's host>
# EMAIL_PORT=<your SMTP provider's port>
# EMAIL_USER=<sending email address>
# EMAIL_PASS=<SMTP password / app password>

