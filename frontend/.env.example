# ==============================================================================
# FRONTEND ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in real values.
# Vite requires all client-side env vars to be prefixed with VITE_
#
# This project keeps LOCAL and PRODUCTION values in the same .env file —
# only one block should be uncommented (active) at a time.
# ==============================================================================

# ---------- LOCAL ----------
VITE_BACKEND_URL=http://localhost:5000

# ---------- PRODUCTION (commented out — set your deployed backend URL before building) ----------
# VITE_BACKEND_URL=<production backend URL, e.g. https://api.yourdomain.com>
